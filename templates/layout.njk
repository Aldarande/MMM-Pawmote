<div class="pm-wrap">

  {# ── En-tête ──────────────────────────────────────────────────────── #}
  {% if userData.name or userData.className or userData.establishment %}
  <div class="pm-header">
    <div class="pm-header-dot"></div>
    {% if config.Header.displayStudentName and userData.name %}
      <span class="pm-name">{{ userData.name | escape }}</span>
    {% endif %}
    {% if config.Header.displayStudentClass and userData.className %}
      <span class="pm-class">{{ userData.className | escape }}</span>
    {% endif %}
    {% if config.Header.displayEstablishmentName and userData.establishment %}
      <span class="pm-estab">{{ userData.establishment | escape }}</span>
    {% endif %}
  </div>
  {% endif %}

  {# ── Timeline ─────────────────────────────────────────────────────── #}
  <div class="pm-timeline">

    {# ── Aujourd'hui ─────────────────────────────────────────────── #}
    {% if showToday and userData.timetableToday | length > 0 %}
    <div class="pm-section pm-section--today">
      <div class="pm-section-head">
        <span class="pm-section-label pm-section-label--today">Aujourd'hui</span>
        {% if userData.todayStart %}
          <span class="pm-section-hours">{{ userData.todayStart | escape }}–{{ userData.todayEnd | escape }}</span>
        {% endif %}
      </div>

      {% for entry in userData.timetableToday %}
        {% if loop.index0 > 0 %}
          {% set prev = userData.timetableToday[loop.index0 - 1] %}
          {% if prev.end <= "14:00" and entry.start >= "11:45" and prev.end < entry.start %}
            <div class="pm-repas">· repas ·</div>
          {% endif %}
        {% endif %}

        <div class="pm-lesson{% if entry.cancelled %} pm-lesson--cancelled{% elif entry.isDetention %} pm-lesson--detention{% endif %}">
          <span class="pm-lesson-time">{{ entry.start | escape }}</span>
          <span class="pm-lesson-subject">{{ entry.subject | escape }}</span>
          {% if entry.cancelled %}
            <span class="pm-lesson-badge">ANN</span>
          {% elif entry.isDetention %}
            <span class="pm-lesson-badge">RET</span>
          {% else %}
            {% if config.Timetable.displayRoom and entry.room %}
              <span class="pm-lesson-meta">{{ entry.room | escape }}</span>
            {% elif config.Timetable.displayTeacher and entry.teacher %}
              <span class="pm-lesson-meta">{{ entry.teacher | escape }}</span>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>
    {% endif %}

    {# ── Prochain jour scolaire ──────────────────────────────────── #}
    {% if showNextDay %}
    <div class="pm-section">
      <div class="pm-section-head">
        <span class="pm-section-label">{{ userData.timetableNextDay.day | escape or "Demain" }}</span>
        {% if userData.timetableNextDay.start %}
          <span class="pm-section-hours">{{ userData.timetableNextDay.start | escape }}–{{ userData.timetableNextDay.end | escape }}</span>
        {% endif %}
      </div>

      {% if userData.timetableNextDay.classes | length == 0 %}
        <div class="pm-empty">Pas de cours</div>
      {% else %}
        {% for entry in userData.timetableNextDay.classes %}
          {% if loop.index0 > 0 %}
            {% set prev = userData.timetableNextDay.classes[loop.index0 - 1] %}
            {% if prev.end <= "14:00" and entry.start >= "11:45" and prev.end < entry.start %}
              <div class="pm-repas">· repas ·</div>
            {% endif %}
          {% endif %}

          <div class="pm-lesson{% if entry.cancelled %} pm-lesson--cancelled{% elif entry.isDetention %} pm-lesson--detention{% endif %}">
            <span class="pm-lesson-time">{{ entry.start | escape }}</span>
            <span class="pm-lesson-subject">{{ entry.subject | escape }}</span>
            {% if entry.cancelled %}
              <span class="pm-lesson-badge">ANN</span>
            {% elif entry.isDetention %}
              <span class="pm-lesson-badge">RET</span>
            {% else %}
              {% if config.Timetable.displayRoom and entry.room %}
                <span class="pm-lesson-meta">{{ entry.room | escape }}</span>
              {% elif config.Timetable.displayTeacher and entry.teacher %}
                <span class="pm-lesson-meta">{{ entry.teacher | escape }}</span>
              {% endif %}
            {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </div>
    {% endif %}

    {# ── Devoirs ─────────────────────────────────────────────────── #}
    {% if showHomeworks %}
      {% set pendingCount = 0 %}
      {% for hw in userData.homeworks %}
        {% if not hw.done %}{% set pendingCount = pendingCount + 1 %}{% endif %}
      {% endfor %}

      {% if pendingCount > 0 or (config.Homeworks.displayDone and userData.homeworks | length > 0) %}
      <div class="pm-section">
        <div class="pm-section-head">
          <span class="pm-section-label">Devoirs</span>
          {% if pendingCount > 0 %}
            <span class="pm-section-count">{{ pendingCount }} à faire</span>
          {% endif %}
        </div>

        {% set shownDeadline = "" %}
        {% for hw in userData.homeworks %}
          {% if not hw.done %}
            {% if shownDeadline != hw.deadline %}
              <div class="pm-deadline{% if hw.dueTomorrow %} pm-deadline--urgent{% endif %}">
                {% if hw.dueTomorrow %}⚠ Demain{% else %}{{ hw.deadline | escape }}{% endif %}
              </div>
              {% set shownDeadline = hw.deadline %}
            {% endif %}
            <div class="pm-hw">
              <div class="pm-hw-body">
                <div class="pm-hw-subject">{{ hw.subject | escape }}</div>
                {% if config.Homeworks.displayDescription and hw.description %}
                  <div class="pm-hw-desc">{{ hw.description | escape }}</div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}

        {% if config.Homeworks.displayDone %}
          {% set shownDeadline = "" %}
          {% for hw in userData.homeworks %}
            {% if hw.done %}
              {% if shownDeadline != hw.deadline %}
                <div class="pm-deadline">{{ hw.deadline | escape }}</div>
                {% set shownDeadline = hw.deadline %}
              {% endif %}
              <div class="pm-hw pm-hw--done">
                <span class="pm-hw-tick">✓</span>
                <div class="pm-hw-body">
                  <div class="pm-hw-subject">{{ hw.subject | escape }}</div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
      {% endif %}
    {% endif %}

    {# ── Alertes : absences / retards / punitions ────────────────── #}
    {% set absCount = userData.absences   | length %}
    {% set delCount = userData.delays     | length %}
    {% set punCount = userData.punishments| length %}

    {% if absCount > 0 or delCount > 0 or punCount > 0 %}
    <div class="pm-section">
      <div class="pm-alerts">
        {% if absCount > 0 %}
          <span class="pm-badge pm-badge--abs">{{ absCount }} absence{% if absCount > 1 %}s{% endif %}</span>
        {% endif %}
        {% if delCount > 0 %}
          <span class="pm-badge pm-badge--delay">{{ delCount }} retard{% if delCount > 1 %}s{% endif %}</span>
        {% endif %}
        {% if punCount > 0 %}
          <span class="pm-badge pm-badge--pun">{{ punCount }} punition{% if punCount > 1 %}s{% endif %}</span>
        {% endif %}
      </div>

      {% for a in userData.absences %}
      <div class="pm-alert-row">
        <span class="pm-alert-date">{{ a.formattedDate | escape }}</span>
        <span class="pm-alert-info{% if not a.justified %} pm-alert-info--nonjust{% endif %}">
          Absence{% if not a.justified %} · Non justifiée{% endif %}{% if a.reason %} · {{ a.reason | escape }}{% endif %}
        </span>
      </div>
      {% endfor %}

      {% for d in userData.delays %}
      <div class="pm-alert-row">
        <span class="pm-alert-date">{{ d.formattedDate | escape }}</span>
        <span class="pm-alert-info">Retard {{ d.duration | escape }} min{% if d.reason %} · {{ d.reason | escape }}{% endif %}</span>
      </div>
      {% endfor %}

      {% for p in userData.punishments %}
      <div class="pm-alert-row">
        <span class="pm-alert-date">{{ p.formattedDate | escape }}</span>
        <span class="pm-alert-info">{{ p.type | escape }}{% if p.reason %} · {{ p.reason | escape }}{% endif %}</span>
      </div>
      {% endfor %}
    </div>
    {% endif %}

  </div>{# /pm-timeline #}

</div>
