<div class="pm-wrap">

    {# ── En-tête ──────────────────────────────────────────────────── #}
    {% if config.Header.displayStudentName and userData.name %}
    <div class="pm-header">
        <span class="pm-name">{{ userData.name | escape }}</span>
        {% if config.Header.displayStudentClass and userData.className %}
            <span class="pm-class">{{ userData.className | escape }}</span>
        {% endif %}
        {% if config.Header.displayEstablishmentName and userData.establishment %}
            <span class="pm-estab">{{ userData.establishment | escape }}</span>
        {% endif %}
    </div>
    {% endif %}

    {# ── Colonnes (logique calculée dans getTemplateData()) ────────── #}
    <div class="pm-cols {{ colClass }}">

        {# ── Colonne 1 : Aujourd'hui (si des cours) ──────────────── #}
        {% if showToday %}
        <div class="pm-col">
            <div class="pm-col-title">Aujourd'hui<br><span class="pm-col-date">{{ todayLabel }}</span></div>
            {% for entry in userData.timetableToday %}
                {% if loop.index0 > 0 %}
                    {% set prev = userData.timetableToday[loop.index0 - 1] %}
                    {% if prev.end <= "14:00" and entry.start >= "11:45" and prev.end < entry.start %}
                        <div class="pm-repas">Repas</div>
                    {% endif %}
                {% endif %}
                <div class="pm-tl-entry{% if entry.cancelled %} pm-cancelled{% endif %}">
                    <span class="pm-time">{{ entry.start | escape }}–{{ entry.end | escape }}</span>
                    <span class="pm-subject">{{ entry.subject | escape }}</span>
                </div>
            {% endfor %}
        </div>
        {% endif %}

        {# ── Colonne 2 : Prochain jour (toujours visible) ────────── #}
        <div class="pm-col">
            <div class="pm-col-title">{{ userData.timetableNextDay.day | escape or "Demain" }}</div>
            {% if userData.timetableNextDay.classes | length == 0 %}
                <div class="pm-empty">Pas de cours</div>
            {% else %}
                {% for entry in userData.timetableNextDay.classes %}
                    {% if loop.index0 > 0 %}
                        {% set prev = userData.timetableNextDay.classes[loop.index0 - 1] %}
                        {% if prev.end <= "14:00" and entry.start >= "11:45" and prev.end < entry.start %}
                            <div class="pm-repas">Repas</div>
                        {% endif %}
                    {% endif %}
                    <div class="pm-tl-entry{% if entry.cancelled %} pm-cancelled{% endif %}">
                        <span class="pm-time">{{ entry.start | escape }}–{{ entry.end | escape }}</span>
                        <span class="pm-subject">{{ entry.subject | escape }}</span>
                    </div>
                {% endfor %}
            {% endif %}
        </div>

        {# ── Colonne 3 : Devoirs (si des devoirs à faire) ────────── #}
        {% if showHomeworks %}
        <div class="pm-col">
            <div class="pm-col-title">Devoirs</div>
            {% set shownDeadline = None %}
            {% for hw in userData.homeworks %}
                {% if not hw.done %}
                    {% if shownDeadline != hw.deadline %}
                        <div class="pm-hw-deadline">{{ hw.deadline | escape }}</div>
                        {% set shownDeadline = hw.deadline %}
                    {% endif %}
                    <div class="pm-hw">
                        <div class="pm-hw-subject">{{ hw.subject | escape }}</div>
                        {% if hw.description %}
                            <div class="pm-hw-desc">{{ hw.description | escape }}</div>
                        {% endif %}
                    </div>
                {% endif %}
            {% endfor %}
        </div>
        {% endif %}

    </div>

    {# ── Cartouche ────────────────────────────────────────────────── #}
    {% set hasCart = (userData.absences | length > 0) or (userData.delays | length > 0) or (userData.punishments | length > 0) %}
    {% if hasCart %}
    <div class="pm-cartouche">

        {% if userData.absences | length > 0 %}
        <div class="pm-cart-section">
            <div class="pm-cart-title">Absences</div>
            {% for a in userData.absences %}
            <div class="pm-cart-entry">
                <span class="pm-cart-date">{{ a.formattedDate | escape }}</span>
                <span class="pm-cart-info">{{ a.reason | escape }}{% if not a.justified %} · Non justifiée{% endif %}</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if userData.delays | length > 0 %}
        <div class="pm-cart-section">
            <div class="pm-cart-title">Retards</div>
            {% for d in userData.delays %}
            <div class="pm-cart-entry">
                <span class="pm-cart-date">{{ d.formattedDate | escape }}</span>
                <span class="pm-cart-info">{{ d.duration | escape }} min{% if d.reason %} · {{ d.reason | escape }}{% endif %}</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if userData.punishments | length > 0 %}
        <div class="pm-cart-section">
            <div class="pm-cart-title">Punitions</div>
            {% for p in userData.punishments %}
            <div class="pm-cart-entry">
                <span class="pm-cart-date">{{ p.formattedDate | escape }}</span>
                <span class="pm-cart-info">{{ p.type | escape }}{% if p.reason %} · {{ p.reason | escape }}{% endif %}</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}

    </div>
    {% endif %}

</div>
