<div id="PRONOTE_LOADING">
    <div id="PRONOTE_LOGO"></div>
</div>
<div id="PRONOTE_ERROR">
    {% if error.message %}
        {{ error.message | safe }}
    {% else %}
        {{ error | safe }}
    {% endif %}
    {% if error.configUrl %}
        <div id="PRONOTE_CONFIG_LINK">
            ⚙ Configurez le module : <span class="highlight">{{ error.configUrl }}</span>
        </div>
    {% endif %}
</div>
